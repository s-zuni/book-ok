{
    "tech_stack": [
        "TypeScript",
        "Next.js",
        "React",
        "Supabase",
        "TailwindCSS"
    ],
    "features": [
        {
            "name": "Librarian Books API",
            "description": "Fetches recommended books from the National Library for Children and Young Adults (NLCF) API.",
            "files": [
                "app/api/librarian-books/route.ts"
            ],
            "api_doc": {
                "openapi": "3.0.0",
                "info": {
                    "title": "Librarian Books API",
                    "version": "1.0.0"
                },
                "paths": {
                    "/api/librarian-books": {
                        "get": {
                            "summary": "Get librarian recommended books",
                            "responses": {
                                "200": {
                                    "description": "Successful response",
                                    "content": {
                                        "application/json": {
                                            "schema": {
                                                "type": "object",
                                                "properties": {
                                                    "response": {
                                                        "type": "object"
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        {
            "name": "Search API",
            "description": "Searches for books using the Aladin Open API.",
            "files": [
                "app/api/search/route.ts"
            ],
            "api_doc": {
                "openapi": "3.0.0",
                "info": {
                    "title": "Search API",
                    "version": "1.0.0"
                },
                "paths": {
                    "/api/search": {
                        "get": {
                            "summary": "Search books",
                            "parameters": [
                                {
                                    "name": "query",
                                    "in": "query",
                                    "required": true,
                                    "schema": {
                                        "type": "string"
                                    }
                                },
                                {
                                    "name": "page",
                                    "in": "query",
                                    "required": false,
                                    "schema": {
                                        "type": "string"
                                    }
                                }
                            ],
                            "responses": {
                                "200": {
                                    "description": "Successful search results"
                                }
                            }
                        }
                    }
                }
            }
        },
        {
            "name": "Frontend - Search Page",
            "description": "Search results page that displays books found via the Search API.",
            "files": [
                "app/search/page.tsx"
            ]
        },
        {
            "name": "Frontend - Home Page",
            "description": "Main landing page displaying librarian and expert recommendations.",
            "files": [
                "app/page.tsx",
                "components/HomeContent.tsx"
            ]
        }
    ]
}